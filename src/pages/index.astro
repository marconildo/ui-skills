          >
            Skills
          </h2>
          <div class="grid gap-4 px-4 sm:grid-cols-2 sm:px-0">
            {
              displayedSkills.map((skill) => (
                <SkillCard
                  href={`/skills/${skill.pathSlug}`}
                  slug={skill.slug}
                  description={skill.description}
                  ownerLabel={skill.ownerLabel}
                  avatarUrl={skill.avatarUrl}
                />
              ))
            }
          </div>
          <div class="mt-4 flex justify-center px-4 sm:px-0">
            <Button href="/skills"> See all skills </Button>
