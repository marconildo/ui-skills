---
import Layout from "../layouts/Layout.astro";
import { skills } from "../data/skills";
import Button from "../ui/button.astro";
import SkillCard from "../ui/skill-card.astro";

const MAX_SKILLS = 18;

const displayedSkills = [...skills]
  .sort((a, b) => {
    const aIsMine = (a.sourceKey ?? "") === "ibelick";
    const bIsMine = (b.sourceKey ?? "") === "ibelick";

    if (aIsMine && !bIsMine) return -1;
    if (!aIsMine && bIsMine) return 1;

    return a.pathSlug.localeCompare(b.pathSlug);
  })
  .slice(0, MAX_SKILLS)
  .map((skill) => {
    const owner = skill.sourceKey ?? "ibelick";

    return {
      ...skill,
      owner,
      ownerLabel: skill.sourceLabel ?? "Ibelick",
      avatarUrl: `https://github.com/${owner}.png?size=40`,
    };
  });
