---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../ui/breadcrumbs.astro";
import { skills } from "../../data/skills";
import SkillCard from "../../ui/skill-card.astro";

const breadcrumbItems = [{ label: "Home", href: "/" }, { label: "Skills" }];

const mixedSkills = [...skills]
  .sort((a, b) => a.pathSlug.localeCompare(b.pathSlug))
  .map((skill) => {
    const owner = skill.sourceKey ?? "ibelick";

    return {
      ...skill,
      ownerLabel: skill.sourceLabel ?? "Ibelick",
      avatarUrl: `https://github.com/${owner}.png?size=40`,
    };
  });

const siteOrigin = Astro.site ?? new URL("https://ui-skills.com");
const skillsIndexUrl = new URL("/skills", siteOrigin).toString();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "UI Skills Library",
  description: "Browse every skill available in this collection.",
  url: skillsIndexUrl,
  hasPart: {
    "@type": "ItemList",
    itemListElement: mixedSkills.map((skill, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: new URL(`/skills/${skill.pathSlug}`, siteOrigin).toString(),
      name: skill.label,
    })),
  },
};
---

<Layout
  structuredData={structuredData}
  title="All Skills - UI Skills"
  description="Browse every UI Skill available in the collection, including local and registry skills for design engineering workflows."
>
  <div
    class="relative flex min-h-dvh flex-col items-center justify-start px-0 sm:px-4"
  >
    <div class="relative mt-20 w-full max-w-3xl sm:px-0">
      <div class="mx-auto flex w-full flex-col gap-10">
        <Breadcrumbs items={breadcrumbItems} />

        <div class="px-4 sm:px-0">
          <h1 class="text-parchment-900 text-3xl font-medium tracking-tight">
            All Skills
          </h1>
          <p class="text-parchment-500 mt-3 text-[15px]">
            Browse every skill available in this collection.
          </p>
        </div>

        <div class="grid gap-4 px-4 sm:grid-cols-2 lg:grid-cols-3 sm:px-0">
          {
            mixedSkills.map((skill) => (
              <SkillCard
                href={`/skills/${skill.pathSlug}`}
                slug={skill.slug}
                description={skill.description}
                ownerLabel={skill.ownerLabel}
                avatarUrl={skill.avatarUrl}
              />
            ))
          }
        </div>
      </div>
    </div>
  </div>
</Layout>
