---
import Layout from "../../layouts/Layout.astro";
import { skills } from "../../data/skills";
import Breadcrumbs from "../../ui/breadcrumbs.astro";

const registrySkills = skills.filter((skill) => skill.isRegistry);

const commonPrefix = (paths: string[]) => {
  if (paths.length === 0) {
    return "";
  }

  const splitPaths = paths.map((path) => path.split("/"));
  const first = splitPaths[0] ?? [];
  const prefix: string[] = [];

  for (let i = 0; i < first.length; i += 1) {
    const segment = first[i];
    if (!segment) {
      break;
    }

    if (splitPaths.every((segments) => segments[i] === segment)) {
      prefix.push(segment);
      continue;
    }

    break;
  }

  return prefix.join("/");
};

const groups = Array.from(
  registrySkills
    .reduce(
      (map, skill) => {
        const sourceKey = skill.sourceKey ?? "other";
        const sourceLabel = skill.sourceLabel ?? "Other";
        const current = map.get(sourceKey);

        if (current) {
          current.skills.push(skill);
          return map;
        }

        map.set(sourceKey, {
          sourceLabel,
          skills: [skill],
        });
        return map;
      },
      new Map<
        string,
        {
          sourceLabel: string;
          skills: typeof registrySkills;
        }
      >(),
    )
    .values(),
)
  .map((group) => ({
    ...group,
    groupPath: commonPrefix(group.skills.map((skill) => skill.pathSlug)),
  }))
  .sort((a, b) => a.sourceLabel.localeCompare(b.sourceLabel));

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Curated skills" },
];
---

<Layout>
  <div class="relative flex min-h-dvh flex-col items-center justify-start px-0 sm:px-4">
    <div class="relative mt-20 w-full max-w-3xl sm:px-0">
      <div class="mx-auto flex w-full flex-col gap-10">
        <Breadcrumbs items={breadcrumbItems} />

        <div class="px-4 sm:px-0">
          <h1 class="text-parchment-900 text-3xl font-medium tracking-tight">
            Curated Skills
          </h1>
        </div>

        <div class="flex flex-col gap-8 px-4 sm:px-0">
          {
            groups.map((group) => (
              <section class="scroll-mt-24">
                <h2 class="text-parchment-800 mb-3 text-sm font-semibold tracking-tight">
                  <a
                    href={`/skills/${group.groupPath}`}
                    class="hover:text-parchment-900 transition-colors"
                  >
                    {group.sourceLabel}
                  </a>
                </h2>
                <div class="grid gap-4 sm:grid-cols-2">
                  {group.skills.slice(0, 2).map((skill) => (
                    <a
                      href={`/skills/${skill.pathSlug}`}
                      class="hover:border-parchment-300 hover:bg-parchment-100 relative flex flex-col justify-between rounded-[12px] border border-neutral-200 bg-transparent px-6 py-4 transition-colors"
                    >
                      <div class="flex flex-col gap-1">
                        <div class="text-parchment-900 font-[450] tracking-tight">
                          {skill.pathSlug}
                        </div>
                        {skill.description ? (
                          <div class="text-parchment-500 line-clamp-3 text-[14px] leading-snug">
                            {skill.description}
                          </div>
                        ) : null}
                      </div>
                    </a>
                  ))}
                  {
                    group.skills.length > 2 ? (
                      <a
                        href={`/skills/${group.groupPath}`}
                        class="hover:border-parchment-300 hover:bg-parchment-100 relative flex flex-col justify-between rounded-[12px] border border-neutral-200 bg-transparent px-6 py-4 transition-colors"
                      >
                        <div class="flex flex-col gap-1">
                          <div class="text-parchment-900 font-[450] tracking-tight">
                            More skills
                          </div>
                          <div class="text-parchment-500 text-[14px] leading-snug">
                            {group.skills.length - 2} more
                          </div>
                        </div>
                      </a>
                    ) : null
                  }
                </div>
              </section>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</Layout>
